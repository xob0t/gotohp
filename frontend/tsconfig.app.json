{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "outDir": "./dist",
      "types": ["vite/client"],
      "moduleResolution": "Bundler"
    },
    "include": [
      "src/**/*.ts",
      "src/**/*.d.ts",
      "src/**/*.tsx",
      "src/**/*.vue"
    ],
    "exclude": ["node_modules"]
  }
